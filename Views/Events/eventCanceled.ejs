<!DOCTYPE html>
<html>

<head>
    <title>Canceled Events</title>
    <link href="/css/bootstrap.css" rel="stylesheet" />
    <link href="/css/font-awesome.css" rel="stylesheet" />
    <%- include("../adminNavbar.ejs") %>
        <style>
            .event-card {
                border-left: 4px solid #dc3545;
                transition: all 0.3s ease;
                margin-bottom: 20px;
            }

            .event-card:hover {
                box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            }

            .btn-details {
                background-color: #17a2b8;
                color: white;
                transition: all 0.3s ease;
            }

            .btn-details:hover {
                background-color: #138496;
                color: white;
                transform: translateY(-2px);
            }
        </style>
</head>

<body>
    <div class="container mt-4">
        <h2>My Canceled Events</h2>
        <div class="row mt-4">
            <% if (canceledEvents.length===0) { %>
                <div class="col-12">
                    <p>No canceled events found.</p>
                </div>
                <% } else { %>
                    <% canceledEvents.forEach(event=> { %>
                        <div class="col-md-6 mb-4">
                            <div class="card event-card">
                                <div class="card-body">
                                    <h5 class="card-title text-danger">
                                        <%= event.title %>
                                    </h5>
                                    <p class="card-text">
                                        <strong>Date:</strong>
                                        <%= new Date(event.date).toLocaleDateString() %><br>
                                            <strong>Time:</strong>
                                            <%= event.startTime %> - <%= event.endTime %><br>
                                                    <strong>Location:</strong>
                                                    <%= event.location %>
                                    </p>
                                    <a href="/admin/canceled-events#event-<%= event._id %>" class="btn btn-details">
                                        <i class="fa fa-info-circle"></i> View Full Details
                                    </a>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                            <% } %>
        </div>
    </div>
</body>

</html>