<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">

<head>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Edit Speaker</title>
    <link href="/css/bootstrap.css" rel="stylesheet" />
    <link href="/css/font-awesome.css" rel="stylesheet" />
    <style>
        :root {
            --primary-color: #2c3e50;
            --secondary-color: #3498db;
            --accent-color: #e74c3c;
        }

        body {
            background-color: #f5f6fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .container {
            margin-top: 30px;
            background: white;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.1);
        }

        h1 {
            color: var(--primary-color);
            margin-bottom: 30px;
            font-weight: 600;
            position: relative;
            padding-bottom: 10px;
        }

        h1:after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 100px;
            height: 4px;
            background: var(--secondary-color);
            border-radius: 2px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            color: var(--primary-color);
            font-weight: 500;
            margin-bottom: 8px;
        }

        .form-control {
            border: 2px solid #e9ecef;
            border-radius: 5px;
            padding: 10px 15px;
            transition: all 0.3s ease;
        }

        .form-control:focus {
            border-color: var(--secondary-color);
            box-shadow: 0 0 0 0.2rem rgba(52, 152, 219, 0.25);
        }

        .form-control[readonly] {
            background-color: #f8f9fa;
            cursor: not-allowed;
        }

        select.form-control {
            height: 45px;
        }

        .btn-primary {
            background-color: var(--secondary-color);
            border: none;
            padding: 12px 30px;
            font-weight: 600;
            letter-spacing: 0.5px;
            border-radius: 5px;
            transition: all 0.3s ease;
            width: 100%;
        }

        .btn-primary:hover {
            background-color: var(--primary-color);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
        }

        .form-group.required label:after {
            content: "*";
            color: var(--accent-color);
            margin-left: 4px;
        }

        @media (max-width: 768px) {
            .container {
                padding: 15px;
            }

            .col-6.offset-3 {
                width: 100%;
                margin-left: 0;
            }
        }
    </style>
</head>

<body>
    <%- include("./../adminNavbar.ejs") %>
        <div class="container">
            <h1 align="Center">Edit Speaker</h1>
            <form class="col-6 offset-3" action="/speaker/update" method="POST">
                <div class="form-group">
                    <label>ID</label>
                    <input type="text" class="form-control" value="<%=speaker._id%>" name="_id" readonly>
                </div>
                <div class="form-group required">
                    <label>Full Name</label>
                    <input type="text" class="form-control" name="fullName" value="<%=speaker.fullName%>" required />
                </div>
                <div class="form-group required">
                    <label>Username</label>
                    <input type="text" class="form-control" name="username" value="<%=speaker.username%>" required />
                </div>
                <div class="form-group required">
                    <label>Email</label>
                    <input type="email" class="form-control" name="email" value="<%=speaker.email%>" required />
                </div>
                <div class="form-group">
                    <label>Phone Number</label>
                    <input type="tel" class="form-control" name="phoneNumber" value="<%=speaker.phoneNumber%>" />
                </div>
                <div class="form-group">
                    <label>Gender</label>
                    <select class="form-control" name="gender">
                        <option value="" <%=!speaker.gender ? 'selected' : '' %>>Select Gender</option>
                        <option value="male" <%=speaker.gender==='male' ? 'selected' : '' %>>Male</option>
                        <option value="female" <%=speaker.gender==='female' ? 'selected' : '' %>>Female</option>
                        <option value="other" <%=speaker.gender==='other' ? 'selected' : '' %>>Other</option>
                    </select>
                </div>
                <div class="form-group required">
                    <label>City</label>
                    <input type="text" class="form-control" name="city" value="<%=speaker.address.city%>" required />
                </div>
                <div class="form-group required">
                    <label>Street</label>
                    <input type="text" class="form-control" name="street" value="<%=speaker.address.street%>"
                        required />
                </div>
                <div class="form-group required">
                    <label>Building</label>
                    <input type="text" class="form-control" name="building" value="<%=speaker.address.building%>"
                        required />
                </div>
                <input type="submit" value="Update Speaker" class="btn btn-primary">
            </form>
        </div>
        <script src="/js/JQuery-3.3.1.min.js"></script>
        <script src="/js/popper.js"></script>
        <script src="/js/bootstrap.js"></script>
</body>

</html>